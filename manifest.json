{
  "manifest_version": 3,
  "name": "Спросить у Алисы",
  "short_name": "Ask Alice",
  "version": "2.0.0",
  "description": "Быстрый текстовый запрос к Алисе — ответ прямо в popup, без переключения вкладок",
  "author": "aerovir",
  "homepage_url": "https://github.com/aerovir/alice-shortcut-extension",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Спросить у Алисы (Ctrl+Shift+A)",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://yandex.ru/alice*",
        "https://alice.yandex.ru/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "host_permissions": [
    "https://yandex.ru/alice*",
    "https://alice.yandex.ru/*"
  ],

  "permissions": [
    "storage",
    "contextMenus"
  ],

  "omnibox": {
    "keyword": "alice"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+A",
        "windows": "Ctrl+Shift+A",
        "mac": "Command+Shift+A",
        "linux": "Ctrl+Shift+A"
      },
      "description": "Открыть строку ввода для Алисы"
    }
  }
}
