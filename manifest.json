{
  "manifest_version": 3,
  "name": "Спросить у Алисы",
  "version": "1.0.0",
  "description": "Быстрый текстовый запрос к Алисе",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Спросить у Алисы",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://yandex.ru/alice*", "https://alice.yandex.ru/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://yandex.ru/alice*",
    "https://alice.yandex.ru/*"
  ],
  "permissions": [
    "contextMenus"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+A",
        "windows": "Ctrl+Shift+A",
        "mac": "Command+Shift+A",
        "linux": "Ctrl+Shift+A"
      },
      "description": "Открыть строку ввода для Алисы"
    }
  }
}
